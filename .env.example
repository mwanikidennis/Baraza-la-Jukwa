# JUKWA Environment Variables
# Copy to .env and fill with real values

# =============================================================================
# DATABASE TIER
# =============================================================================
# JUKWA uses a hybrid database architecture:
#   - Supabase (PostgreSQL + PostGIS) = primary relational/spatial database
#   - MongoDB = time-series telemetry (traffic sensors)
#   - Redis = caching/sessions (optional for MVP)
#   - Mosquitto MQTT = real-time pub/sub (NOT replaced by Supabase Realtime)
#
# Set DATABASE_MODE to "supabase" for cloud or "local" for Docker PostgreSQL

DATABASE_MODE=supabase

# Supabase (Cloud) -- Primary database for production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Local PostgreSQL (Docker) -- Fallback for offline development
DB_USER=jukwaa
DB_PASSWORD=jukwaa_secret
DB_NAME=jukwaa
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# MongoDB (Docker) -- Time-series telemetry for traffic sensors
# NOT replaced by Supabase -- MongoDB is purpose-built for high-write sensor data
MONGODB_URI=mongodb://mongodb:27017/jukwaa_telemetry

# Redis (Docker) -- Caching and sessions
# Optional for MVP -- identity service uses it for token caching
# If unavailable, services degrade gracefully (no crash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# =============================================================================
# MESSAGING TIER
# =============================================================================
# Mosquitto MQTT -- Real-time pub/sub
# NOT replaced by Supabase Realtime -- MQTT uses less bandwidth on 3G,
# has QoS guarantees, and topic-level ACL security
MQTT_URL=mqtt://mosquitto:1883

# =============================================================================
# OBJECT STORAGE
# =============================================================================
# MinIO -- Media storage (photos, audio recordings)
MINIO_USER=admin
MINIO_PASSWORD=admin12345
MINIO_ENDPOINT=localhost:9000

# =============================================================================
# AI & NOTIFICATIONS
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key
FCM_SERVER_KEY=your_fcm_server_key

# =============================================================================
# CITIZEN VAULT (Privacy)
# =============================================================================
VAULT_KEY=your_32_byte_vault_encryption_key

# =============================================================================
# KENYAN PAYMENT INTEGRATIONS (Phase 2)
# =============================================================================
# Africa's Talking (SMS fallback for 2G)
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key

# Safaricom Daraja (M-Pesa)
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_PASSKEY=your_passkey

# =============================================================================
# APP SETTINGS
# =============================================================================
NODE_ENV=development
JWT_SECRET=super_secret_jwt_key
